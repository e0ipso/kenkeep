{
  "version": 1,
  "hooks": {
    "stop": [
      {
        "command": "node ./.ai/kenkeep/hooks/cursor/kk-capture.cjs",
        "timeout": 30
      }
    ],
    "sessionEnd": [
      {
        "command": "node ./.ai/kenkeep/hooks/cursor/kk-capture.cjs",
        "timeout": 30
      },
      {
        "command": "node ./.ai/kenkeep/hooks/cursor/kk-lint-tick.cjs",
        "timeout": 30
      }
    ],
    "preCompact": [
      {
        "command": "node ./.ai/kenkeep/hooks/cursor/kk-capture.cjs",
        "timeout": 30
      }
    ],
    "sessionStart": [
      {
        "command": "node ./.ai/kenkeep/hooks/cursor/kk-session-start.cjs",
        "timeout": 30
      },
      {
        "command": "node ./.ai/kenkeep/hooks/cursor/kk-proposal-drain.cjs",
        "timeout": 30
      }
    ]
  }
}
