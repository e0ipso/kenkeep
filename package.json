{
  "name": "@e0ipso/ai-knowledge-base",
  "version": "0.26.4",
  "description": "Builds and maintains a per-repo knowledge base from AI coding sessions, for use with Claude Code.",
  "license": "MIT",
  "author": "e0ipso",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/e0ipso/ai-knowledge-base.git"
  },
  "homepage": "https://github.com/e0ipso/ai-knowledge-base#readme",
  "bugs": {
    "url": "https://github.com/e0ipso/ai-knowledge-base/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "knowledge-base",
    "ai",
    "agents"
  ],
  "type": "module",
  "bin": {
    "ai-knowledge-base": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "npm run build:cli && npm run build:templates",
    "build:cli": "tsup",
    "build:templates": "node ./scripts/build-templates.mjs",
    "dev": "tsup --watch",
    "lint": "eslint . && npm run lint:detect-harness",
    "lint:detect-harness": "node scripts/lint-detect-harness.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "commitlint": "commitlint --edit",
    "security:audit": "npm audit",
    "security:audit-json": "npm audit --json",
    "security:fix": "npm audit fix",
    "security:fix-force": "npm audit fix --force",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "commander": "^13.0.0",
    "execa": "^9.5.2",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.5",
    "js-yaml": "^4.1.0",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "proper-lockfile": "^4.1.2",
    "smol-toml": "^1.6.1",
    "split2": "^4.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "@semantic-release/npm": "^13.1.3",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.5",
    "@types/picomatch": "^4.0.3",
    "@types/proper-lockfile": "^4.1.4",
    "@types/split2": "^4.2.3",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.4.2",
    "semantic-release": "^25.0.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
